{
  "name": "bet-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma de apostas esportivas (sportsbook) multi-tenant — odds ao vivo, bet slip e cashout.",
  "scripts": {
    "dev": "concurrently -n web,ws -c blue,green \"next dev\" \"npm:dev:ws\"",
    "dev:web": "next dev",
    "dev:ws": "tsx watch src/server/index.ts",
    "build": "next build",
    "start:web": "next start",
    "start:ws": "tsx src/server/index.ts",
    "feed:test": "tsx src/server/providers/test-feed.ts",
    "feed:harvest": "tsx src/server/providers/harvest.ts",
    "demo:reseed": "tsx src/server/demoReseed.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "ws": "^8.18.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
