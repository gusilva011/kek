# Copie para `.env.local` e preencha as chaves. O .env.local é gitignorado
# (NUNCA suba chaves para o repositório).

# URL do gateway WebSocket (servidor de odds) usada pelo browser.
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Porta do gateway WebSocket.
WS_PORT=4000

# --- Segurança ---
# Senha do administrador do backoffice (/admin, login "admin").
# Se vazio, o demo usa "admin123" — DEFINA antes de ir para produção.
ADMIN_PASSWORD=

# Origens autorizadas a abrir o WebSocket (anti cross-site hijacking).
# Lista separada por vírgula. Em produção, use o domínio real do app.
WS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Fornecedor de dados ---
# Fonte: "live" | "demo" | "apifootball" | "theoddsapi" | "simulation"
#   live = AO VIVO REAL (acervo pré-jogo + /fixtures?live=all). Gasta cota.
#   demo = jogos reais do cache + ao vivo SIMULADO. Não gasta cota (vitrine).
ODDS_PROVIDER=demo

# Intervalo do polling ao vivo (ms). 120s ≈ 50 req/h.
LIVE_POLL_MS=120000

# API-Football (dashboard.api-football.com) — futebol + logos. Grátis 100 req/dia.
# Crie a sua chave e cole aqui.
APIFOOTBALL_KEY=SUA_CHAVE_API_FOOTBALL

# The Odds API (the-odds-api.com) — multi-esporte (NBA, MLB, NFL, tênis, MMA…).
# Grátis 500 req/mês. Crie a sua chave e cole aqui.
ODDS_API_KEY=SUA_CHAVE_THE_ODDS_API
